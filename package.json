{
  "name": "cloud-code-execution-engine",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @ccee/common && npm run build --workspace @ccee/api && npm run build --workspace @ccee/worker && npm run build --workspace @ccee/runner",
    "dev:api": "npm run dev --workspace @ccee/api",
    "dev:worker": "npm run dev --workspace @ccee/worker",
    "dev:runner": "npm run dev --workspace @ccee/runner",
    "queue:recover": "node scripts/replay-dlq.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
