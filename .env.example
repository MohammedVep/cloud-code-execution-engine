# API
API_PORT=8080
REDIS_URL=redis://localhost:6379
AUTH_MODE=api_key
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_TENANT_CLAIM=custom:tenant_id
JWT_SUBJECT_CLAIM=sub
RATE_LIMIT_REQUESTS_PER_MINUTE=240
RATE_LIMIT_WINDOW_SECONDS=60
SUBMIT_RATE_LIMIT_PER_MINUTE=60
MAX_SOURCE_CODE_BYTES=100000
MAX_STDIN_BYTES=100000
JOB_QUEUE_NAME=code-jobs
JOB_TTL_SECONDS=86400
JOB_HISTORY_MAX=500
JOB_LIST_DEFAULT_LIMIT=20
JOB_LIST_MAX_LIMIT=100
AUDIT_STREAM_KEY=audit:events
DAILY_QUOTA_TTL_SECONDS=172800
QUEUE_JOB_ATTEMPTS=3
QUEUE_RETRY_BACKOFF_MS=1000
ANALYSIS_MAX_SOURCE_CHARS=8000
AI_PROVIDER=none
OPENAI_MODEL=gpt-4.1-mini
AI_ANALYSIS_TIMEOUT_MS=10000
AI_ANALYSIS_RETRIES=2
AI_ANALYSIS_RETRY_BACKOFF_MS=500
OPENAI_API_KEY=
TENANT_POLICIES_JSON={}
TENANT_API_KEYS_JSON={"dev-local-key":{"tenantId":"tenant-dev","maxConcurrentJobs":5,"maxDailyJobs":1000}}

# Worker
WORKER_CONCURRENCY=4
QUEUE_JOB_ATTEMPTS=3
QUEUE_RETRY_BACKOFF_MS=1000
EXECUTION_BACKEND=local
RUNNER_IMAGE=ccee-runner:local

# ECS backend settings (required when EXECUTION_BACKEND=ecs)
AWS_REGION=us-east-1
ECS_CLUSTER_ARN=
ECS_TASK_DEFINITION_ARN=
ECS_SUBNET_IDS=subnet-abc,subnet-def
ECS_SECURITY_GROUP_IDS=sg-abc
ECS_ASSIGN_PUBLIC_IP=DISABLED
QUEUE_DEPTH_METRIC_NAMESPACE=CCEE
QUEUE_DEPTH_METRIC_NAME=PendingJobsCount
QUEUE_DEPTH_PUBLISH_INTERVAL_MS=30000
QUEUE_DEPTH_METRIC_SERVICE_NAME=worker

# Runner defaults
MAX_STDIO_BYTES=65536
