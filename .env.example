# API
API_PORT=8080
REDIS_URL=redis://localhost:6379
JOB_QUEUE_NAME=code-jobs
JOB_TTL_SECONDS=86400
JOB_HISTORY_MAX=500
JOB_LIST_DEFAULT_LIMIT=20
JOB_LIST_MAX_LIMIT=100
AUDIT_STREAM_KEY=audit:events
DAILY_QUOTA_TTL_SECONDS=172800
QUEUE_JOB_ATTEMPTS=3
QUEUE_RETRY_BACKOFF_MS=1000
ANALYSIS_MAX_SOURCE_CHARS=8000
TENANT_API_KEYS_JSON={"dev-local-key":{"tenantId":"tenant-dev","maxConcurrentJobs":5,"maxDailyJobs":1000}}

# Worker
WORKER_CONCURRENCY=4
QUEUE_JOB_ATTEMPTS=3
QUEUE_RETRY_BACKOFF_MS=1000
EXECUTION_BACKEND=local
RUNNER_IMAGE=ccee-runner:local

# ECS backend settings (required when EXECUTION_BACKEND=ecs)
AWS_REGION=us-east-1
ECS_CLUSTER_ARN=
ECS_TASK_DEFINITION_ARN=
ECS_SUBNET_IDS=subnet-abc,subnet-def
ECS_SECURITY_GROUP_IDS=sg-abc
ECS_ASSIGN_PUBLIC_IP=DISABLED

# Runner defaults
MAX_STDIO_BYTES=65536
